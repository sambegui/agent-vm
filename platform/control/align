#!/usr/bin/env bash
# align — assert the running container digest == the manifest's pinned digest. Runs in agent-platform.
# Usage: align <manifest.yaml>
set -euo pipefail
M="${1:?need a manifest path}"
name="$(grep -E '^  name:' "$M" | head -1 | awk '{print $2}')"
want="$(grep -E '^  image:' "$M" | head -1 | awk '{print $2}' | sed 's/.*@//')"
got="$(podman inspect "systemd-$name" --format '{{.ImageDigest}}' 2>/dev/null || echo none)"
got="${got##*@}"
echo "want=$want got=$got"
[ "$want" = "$got" ] && { echo "ALIGNED"; exit 0; } || { echo "DRIFT"; exit 1; }
