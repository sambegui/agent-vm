#!/usr/bin/env bash
# acceptance — runs the walking-skeleton acceptance subset against the configured VM. Host-side.
set -euo pipefail
AGENT_VM_SSH="${AGENT_VM_SSH:-agent-platform}"
BUSYBOX_DIGEST="sha256:7b9a320334d446845c17edcfad9bdd1d54ad05c84c35b117e8fa7d830b9fcce5"

remote() {
  # shellcheck disable=SC2029 # Commands are intentionally executed on the configured VM.
  ssh "$AGENT_VM_SSH" "$@"
}

remote "cat > /tmp/egress-job.json <<JSON
{ \"jobId\":\"egress-001\",\"requester\":\"hello\",\"image\":\"127.0.0.1:5000/busybox@$BUSYBOX_DIGEST\",
  \"command\":[\"sh\",\"-c\",\"wget -T 5 -q -O- http://1.1.1.1 2>/dev/null && echo REACHED || echo BLOCKED\"],
  \"egress\":{\"default\":\"deny\"},\"timeout\":30 }
JSON"

remote "cat > /tmp/dns-exfiltration-job.json <<JSON
{ \"jobId\":\"dns-exfiltrate-001\",\"requester\":\"hello\",\"image\":\"127.0.0.1:5000/busybox@$BUSYBOX_DIGEST\",
  \"command\":[\"sh\",\"-c\",\"nslookup malicious-domain.com 2>/dev/null && echo RESOLVED || echo BLOCKED\"],
  \"egress\":{\"default\":\"deny\"},\"timeout\":30 }
JSON"

pass=0
fail=0
check() {
  local name="$1"
  shift
  if "$@"; then
    echo "PASS $name"
    pass=$((pass + 1))
  else
    echo "FAIL $name"
    fail=$((fail + 1))
  fi
}

check "tier1.health" remote 'curl -fsS http://127.0.0.1:18080/healthz | grep -q ok'
check "alignment.aligned" remote "\$HOME/platform/control/align \$HOME/platform/manifests/hello.service.yaml | grep -q ALIGNED"
check "tier2.microvm_boots" remote "\$HOME/platform/sandbox/sandbox-runner \$HOME/platform/sandbox/jobspec.example.json | grep -q hello-from-microvm"
check "tier2.egress_deny" remote "\$HOME/platform/sandbox/sandbox-runner /tmp/egress-job.json | grep -q BLOCKED"
check "tier2.dns_exfiltrate_deny" remote "\$HOME/platform/sandbox/sandbox-runner /tmp/dns-exfiltration-job.json | grep -q BLOCKED"
check "tier2.teardown" remote "\$HOME/platform/sandbox/sandbox-runner \$HOME/platform/sandbox/jobspec.example.json | grep -q \"0 residual\""
echo "---"
echo "PASS=$pass FAIL=$fail"
[ "$fail" -eq 0 ]
