#!/usr/bin/env bash
# destroy-vm — tear down agent-platform (idempotent). Host-side.
set -euo pipefail
VIRSH="virsh -c qemu:///system"
$VIRSH destroy agent-platform 2>/dev/null || true
$VIRSH undefine agent-platform 2>/dev/null || true
sudo rm -f /var/lib/libvirt/images/agent-platform/agent-platform.qcow2 \
           /var/lib/libvirt/images/agent-platform/seed.iso
echo "agent-platform destroyed (base image retained)"
