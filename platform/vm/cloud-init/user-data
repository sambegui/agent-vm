#cloud-config
users:
  - name: agent
    groups: [kvm]
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    ssh_authorized_keys:
      - REPLACE_WITH_AGENT_PLATFORM_PUBKEY
package_update: true
packages: [podman, qemu-utils, nftables, curl, jq, uidmap, slirp4netns, dbus-user-session]
bootcmd:
  - [ mkdir, -p, /etc/systemd/resolved.conf.d ]
  - [ sh, -c, "printf '[Resolve]\nDNS=10.0.0.1\nFallbackDNS=10.0.0.1\nDomains=~.\n' >/etc/systemd/resolved.conf.d/10-agent-platform.conf" ]
  - [ sh, -c, "systemctl restart systemd-resolved || true" ]
runcmd:
  - [ systemctl, enable, --now, podman.socket ]
  - [ loginctl, enable-linger, agent ]
write_files:
  - path: /etc/sysctl.d/90-unpriv-userns.conf
    content: "kernel.unprivileged_userns_clone=1\n"
