#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
ACCEPTANCE="$ROOT/platform/validate/acceptance"

tmp="$(mktemp -d)"
trap 'rm -rf "$tmp"' EXIT

fakebin="$tmp/bin"
mkdir -p "$fakebin"

cat > "$fakebin/ssh" <<'SH'
#!/usr/bin/env bash
host="$1"
shift
echo "$host" >> "$SSH_HOST_LOG"
printf '%s\n' "$*" >> "$SSH_COMMAND_LOG"
exit 0
SH
chmod +x "$fakebin/ssh"

SSH_HOST_LOG="$tmp/hosts.log"
SSH_COMMAND_LOG="$tmp/commands.log"
export SSH_HOST_LOG SSH_COMMAND_LOG

PATH="$fakebin:$PATH" AGENT_VM_SSH=custom-host bash "$ACCEPTANCE" > "$tmp/out"

grep -q 'PASS=6 FAIL=0' "$tmp/out"
if grep -Fxvq 'custom-host' "$SSH_HOST_LOG"; then
  echo "acceptance did not use AGENT_VM_SSH for every ssh call" >&2
  echo "--- hosts ---" >&2
  cat "$SSH_HOST_LOG" >&2
  exit 1
fi

echo "acceptance tests passed"
