require_text() {
  local file="$1"
  local text="$2"
  if ! grep -Fqi "$text" "$file"; then
    echo "missing required public docs text in $file: $text" >&2
    exit 1
  fi
}

forbid_text() {
  local file="$1"
  local text="$2"
  if grep -Fqi "$text" "$file"; then
    echo "forbidden public docs text in $file: $text" >&2
    exit 1
  fi
}

hex_to_text() {
  local hex="$1"
  local out=""
  local i
  local char
  if (( ${#hex} % 2 != 0 )); then
    echo "invalid hex fixture length" >&2
    exit 1
  fi
  for ((i = 0; i < ${#hex}; i += 2)); do
    printf -v char '%b' "\\x${hex:i:2}"
    out+="$char"
  done
  printf '%s' "$out"
}

forbid_hex_text() {
  local file="$1"
  local hex="$2"
  local label="$3"
  local text
  text="$(hex_to_text "$hex")"
  if grep -Fqi "$text" "$file"; then
    echo "forbidden public docs text in $file: $label" >&2
    exit 1
  fi
}

forbid_literal_fixture() {
  local hex="$1"
  local label="$2"
  local text
  text="$(hex_to_text "$hex")"
  if grep -Fqi "$text" "$0"; then
    echo "literal negative fixture leaked in docs contract test: $label" >&2
    exit 1
  fi
}

