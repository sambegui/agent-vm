require_text() {
  local file="$1"
  local text="$2"
  if ! grep -Fqi "$text" "$file"; then
    echo "missing required public docs text in $file: $text" >&2
    exit 1
  fi
}

forbid_text() {
  local file="$1"
  local text="$2"
  if grep -Fqi "$text" "$file"; then
    echo "forbidden public docs text in $file: $text" >&2
    exit 1
  fi
}

forbid_hash_text() {
  local file="$1"
  local length="$2"
  local expected_sha="$3"
  local label="$4"
  python3 - "$file" "$length" "$expected_sha" "$label" <<'PY'
import hashlib
import sys
from pathlib import Path

path = Path(sys.argv[1])
length = int(sys.argv[2])
expected_sha = sys.argv[3]
label = sys.argv[4]
text = path.read_text(errors="ignore").lower()
if length <= 0:
    raise SystemExit("invalid forbidden text length")
for i in range(0, max(len(text) - length + 1, 0)):
    if hashlib.sha256(text[i:i + length].encode()).hexdigest() == expected_sha:
        print(f"forbidden public docs text in {path}: {label}", file=sys.stderr)
        raise SystemExit(1)
PY
}

forbid_hash_text_tree() {
  local length="$1"
  local expected_sha="$2"
  local label="$3"
  local file
  while IFS= read -r file; do
    forbid_hash_text "$file" "$length" "$expected_sha" "$label"
  done < <(
    find "$ROOT/README.md" "$ROOT/docs" "$ROOT/site" \
      -type f \( -name '*.md' -o -name '*.txt' -o -name '*.html' \) \
      2>/dev/null | sort
  )
}

