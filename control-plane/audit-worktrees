#!/usr/bin/env bash
# audit-worktrees — inventory ~/work/agent-* and worktrees/ into state/inventory.md.
# Host-only, read-only w.r.t. the checkouts; writes the inventory file.
set -euo pipefail
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
. "$HERE/lib/common.sh"
print_context
banner "inventory ~/work + worktrees -> state/inventory.md"

OUT="$AGENT_VM_ROOT/state/inventory.md"
ts="$(date -u +%FT%TZ)"
{
  echo "# Migration Inventory"
  echo
  echo "_Generated by scripts/audit-worktrees at ${ts}. The Disposition column is hand-edited:_"
  echo "_adopt → worktree / archive / delete. Moves happen later; ~/work removed only after adoption is verified._"
  echo
  echo "| Path | Remote | Branch | HEAD | Disposition |"
  echo "|------|--------|--------|------|-------------|"
  for d in "$HOME"/work/agent-* "$AGENT_VM_ROOT"/worktrees/agent/*; do
    [ -d "$d" ] || continue
    if git -C "$d" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
      remote="$(git -C "$d" remote get-url origin 2>/dev/null || echo '-')"
      branch="$(git -C "$d" rev-parse --abbrev-ref HEAD 2>/dev/null || echo '-')"
      head="$(git -C "$d" rev-parse --short HEAD 2>/dev/null || echo '-')"
    else
      remote='(not a git repo)'; branch='-'; head='-'
    fi
    echo "| \`$d\` | $remote | $branch | $head | TODO |"
  done
} > "$OUT"
log "wrote $OUT"
sed 's/^/   /' "$OUT" >&2
