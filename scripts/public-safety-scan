#!/usr/bin/env python3
"""Scan a public diff for common declassification mistakes.

The default mode scans changed and untracked files only. Pass paths to scan a
specific set of files or directories.
"""

from __future__ import annotations

import os
import pathlib
import re
import subprocess
import sys


ROOT = pathlib.Path(__file__).resolve().parents[1]
SELF = pathlib.Path(__file__).resolve()

TEXT_SUFFIXES = {
    ".md",
    ".txt",
    ".yaml",
    ".yml",
    ".json",
    ".html",
    ".css",
    ".svg",
    ".py",
    ".sh",
    ".service",
    ".toml",
}

SECRET_PATTERNS = [
    ("private-key-block", re.compile(r"-----BEGIN [A-Z ]*PRIVATE KEY-----")),
    ("openai-style-token", re.compile(r"\bsk-[A-Za-z0-9_-]{20,}\b")),
    ("github-token", re.compile(r"\bghp_[A-Za-z0-9_]{20,}\b")),
    ("github-pat", re.compile(r"\bgithub_pat_[A-Za-z0-9_]{20,}\b")),
    ("aws-access-key", re.compile(r"\bAKIA[0-9A-Z]{16}\b")),
    (
        "bearer-token-value",
        re.compile(r"\bAuthorization:\s*Bearer\s+[A-Za-z0-9._~+/-]{16,}", re.IGNORECASE),
    ),
]

PATH_PATTERNS = [
    ("absolute-user-home", re.compile(r"(?<![\w.-])/(?:home|Users)/[A-Za-z0-9._-]+/")),
    ("ssh-private-key-path", re.compile(r"\.ssh/(?:id_rsa|id_ed25519|id_ecdsa)")),
]

BROAD_MOUNT_PATTERNS = [
    ("docker-socket-mount", re.compile(r"/var/run/docker\.sock")),
    ("host-root-mount", re.compile(r"\b(?:source|src|volume|mount):\s*/\s*(?:#.*)?$")),
    ("proc-sys-mount", re.compile(r"\b(?:source|src|volume|mount):\s*/(?:proc|sys)\b")),
]

INLINE_SECRET = re.compile(
    r"(?i)\b(?:password|api[_-]?key|access[_-]?token|secret|token)\s*[:=]\s*['\"]?([A-Za-z0-9._~+/-]{8,})"
)

CONTAINER_REF = re.compile(r"(?i)\bimage\s*:\s*([^#\n]+@sha256:[0-9a-f]{64})")

PLACEHOLDER_WORDS = (
    "example",
    "demo",
    "fake",
    "placeholder",
    "secret://",
    "ref://",
    "000000",
)


def run_git(args: list[str]) -> list[str]:
    try:
        result = subprocess.run(
            ["git", *args],
            cwd=ROOT,
            check=True,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
        )
    except subprocess.CalledProcessError:
        return []
    return [line for line in result.stdout.splitlines() if line.strip()]


def default_paths() -> list[pathlib.Path]:
    changed = run_git(["diff", "--name-only", "--diff-filter=ACMRT", "HEAD", "--"])
    untracked = run_git(["ls-files", "--others", "--exclude-standard"])
    paths = []
    for item in changed + untracked:
        p = (ROOT / item).resolve()
        if p.exists():
            paths.append(p)
    return sorted(set(paths))


def expand_paths(args: list[str]) -> list[pathlib.Path]:
    if not args:
        return default_paths()

    found: list[pathlib.Path] = []
    for arg in args:
        p = (ROOT / arg).resolve()
        if p.is_dir():
            for child in p.rglob("*"):
                if child.is_file():
                    found.append(child)
        elif p.exists():
            found.append(p)
    return sorted(set(found))


def is_text_file(path: pathlib.Path) -> bool:
    if path.resolve() == SELF:
        return False
    if ".git" in path.parts:
        return False
    if path.suffix not in TEXT_SUFFIXES and path.name not in {"README", "LICENSE"}:
        return False
    try:
        chunk = path.read_bytes()[:4096]
    except OSError:
        return False
    return b"\0" not in chunk


def rel(path: pathlib.Path) -> str:
    return str(path.resolve().relative_to(ROOT))


def has_placeholder(line: str) -> bool:
    lower = line.lower()
    return any(word in lower for word in PLACEHOLDER_WORDS)


def scan_file(path: pathlib.Path) -> list[tuple[str, int, str]]:
    findings: list[tuple[str, int, str]] = []
    try:
        lines = path.read_text(encoding="utf-8").splitlines()
    except UnicodeDecodeError:
        lines = path.read_text(encoding="utf-8", errors="replace").splitlines()

    relative = rel(path)
    text = "\n".join(lines)

    if relative.startswith("examples/reference-cell/") and "example_only" not in text:
        findings.append(("missing-example-only-marker", 1, relative))

    for lineno, line in enumerate(lines, start=1):
        for name, pattern in SECRET_PATTERNS + PATH_PATTERNS + BROAD_MOUNT_PATTERNS:
            if pattern.search(line):
                findings.append((name, lineno, line.strip()))

        match = INLINE_SECRET.search(line)
        if match and not has_placeholder(line):
            findings.append(("inline-secret-like-value", lineno, line.strip()))

        image = CONTAINER_REF.search(line)
        if image and not has_placeholder(image.group(1)):
            findings.append(("non-placeholder-image-reference", lineno, line.strip()))

    return findings


def main() -> int:
    paths = [p for p in expand_paths(sys.argv[1:]) if is_text_file(p)]
    findings: list[tuple[str, str, int, str]] = []

    for path in paths:
        for name, lineno, detail in scan_file(path):
            findings.append((rel(path), name, lineno, detail))

    if findings:
        print("public-safety-scan: FAIL")
        for path, name, lineno, detail in findings:
            print(f"{path}:{lineno}: {name}: {detail}")
        return 1

    print(f"public-safety-scan: PASS ({len(paths)} text files scanned)")
    return 0


if __name__ == "__main__":
    os.chdir(ROOT)
    raise SystemExit(main())
